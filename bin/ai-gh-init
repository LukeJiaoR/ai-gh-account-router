#!/usr/bin/env bash
set -euo pipefail

REAL_PATH_FILE="$HOME/.config/ai-gh/real-gh-path"

if [ ! -f "$REAL_PATH_FILE" ]; then
  echo "ai-gh-init: missing $REAL_PATH_FILE" >&2
  exit 127
fi

GH_REAL="$(cat "$REAL_PATH_FILE")"

if [ ! -x "$GH_REAL" ]; then
  echo "ai-gh-init: real gh not executable: $GH_REAL" >&2
  exit 127
fi

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "ai-gh-init: not inside a git repo" >&2
  exit 2
}

accounts="$(
  "$GH_REAL" auth status --hostname github.com 2>&1 \
    | sed -nE \
      -e 's/.*Logged in to github\.com account ([^ ]+).*/\1/p' \
      -e 's/.*Logged in to github\.com as ([^ ]+).*/\1/p' \
    | sort -u
)"

if [ -z "$accounts" ]; then
  echo "ai-gh-init: no logged-in GitHub accounts found. Run: gh auth login" >&2
  exit 2
fi

if [ "${1:-}" != "" ]; then
  user="$1"
else
  echo "Available GitHub accounts:"
  printf "%s\n" "$accounts" | nl -w1 -s") "
  printf "Choose account number: "
  read -r selected
  user="$(printf "%s\n" "$accounts" | sed -n "${selected}p")"
fi

if [ -z "${user:-}" ]; then
  echo "ai-gh-init: invalid selection" >&2
  exit 2
fi

if ! printf "%s\n" "$accounts" | grep -qxF "$user"; then
  echo "ai-gh-init: account '$user' is not logged in to gh" >&2
  echo "Available accounts:"
  printf "%s\n" "$accounts" | sed 's/^/  - /'
  exit 2
fi

root="$(git rev-parse --show-toplevel)"

printf "%s\n" "$user" > "$root/.ai-gh-account"

mkdir -p "$root/.git/info"

grep -qxF ".ai-gh-account" "$root/.git/info/exclude" 2>/dev/null \
  || printf "\n.ai-gh-account\n" >> "$root/.git/info/exclude"

echo "Initialized AI GitHub account tag: $user"
echo "File: $root/.ai-gh-account"
echo "Ignored locally via: $root/.git/info/exclude"
